{
  "version": 1,
  "sdk_version": "0.24.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://xukkejkvcgixogvbllmf.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "verified-bm-shop-mcp",
      "version": "0.1.0",
      "title": "Verified BM Shop"
    },
    "tools": [
      {
        "name": "list_products",
        "title": "List products",
        "description": "List products available on Verified BM Shop (Verified Business Managers, WhatsApp Business API, etc.). Returns title, slug, price, category, stock status, and product URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category filter (e.g. 'BM', 'WhatsApp').",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_product",
        "title": "Get product details",
        "description": "Fetch full details for a single Verified BM Shop product by slug, including description, price, and features.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Product slug (from the product URL)."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_my_orders",
        "title": "List my orders",
        "description": "List the signed-in user's Verified BM Shop orders. Access is scoped via RLS to the authenticated user only.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max orders to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "status": {
              "description": "Optional status filter (pending, completed, cancelled, etc.).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "search_blog",
        "title": "Search blog posts",
        "description": "Search published Verified BM Shop blog posts by keyword in the title or excerpt.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Keyword to search for."
            },
            "limit": {
              "description": "Max posts to return (default 10).",
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
